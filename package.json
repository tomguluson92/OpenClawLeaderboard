{
  "name": "openclaw-leaderboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pipeline": "bun run cli/run.ts",
    "pipeline:ingest": "bun run cli/run.ts ingest",
    "pipeline:process": "bun run cli/run.ts process",
    "pipeline:export": "bun run cli/run.ts export",
    "pipeline:all": "bun run cli/run.ts ingest && bun run cli/run.ts process && bun run cli/run.ts export",
    "db:migrate": "bun run drizzle/migrate.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:studio": "bunx drizzle-kit studio",
    "daily": "bash scripts/daily-sync.sh"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "ora": "^9.1.0",
    "p-map": "^7.0.4",
    "p-retry": "^7.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.10",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.9.3"
  }
}
